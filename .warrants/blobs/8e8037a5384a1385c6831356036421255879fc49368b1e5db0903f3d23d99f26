#!/usr/bin/env python3
"""Adjudication check for the DeepSeek GOV-001 rev 3 gate review (repo root)."""
import subprocess, sys, pathlib
ok = True
# rev 4 integrations present in the proposal text
t = pathlib.Path("proposals/GOV-001-settlement-at-scale.md").read_text()
for needle, label in ((("MUST NOT treat it as a trust anchor"), "genesis advisory P1"),
                      ("maximal, mutually unordered warrants", "maximal-warrant clarification"),
                      ("not part of the tunnel's fingerprint set", "missing-transcript rule"),
                      ("ascending lexicographically", "evidence sort note"),
                      ("no interchangeable\n> `keyring.json` format", "keyring deferral"),
                      ("REVIEW GATE CLOSED, rev 4", "gate closed status")):
    hit = needle in t
    print(("OK  " if hit else "MISS"), label)
    ok &= hit
for cmd, want in ((["impl/warrant.py","selftest"], "ALL PASS"),
                  (["impl/warrant.py","conformance"], "ALL PASS (20/20)"),
                  (["tests/differential.py"], "ALL AGREE (43/43)"),
                  (["tests/negative.py"], "NEGATIVE: ALL AGREE")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]
    print(last)
    ok &= p.returncode == 0 and want in last
print("gov001 gate 3 dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
