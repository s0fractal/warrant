#!/usr/bin/env python3
"""Adjudication check for the Opus 4.8 Warrant v0.2 review (run from repo root).
Verifies the F1-F8 fixes hold: both implementations agree everywhere."""
import subprocess, sys, os
GO = "./impl-go/warrant-go"
ok = True
for cmd, want in (([sys.executable, "impl/warrant.py", "selftest"], "SELFTEST: ALL PASS"),
                  ([sys.executable, "impl/warrant.py", "conformance"], "ALL PASS (20/20)"),
                  ([GO, "selftest"], "ALL PASS (7/7)"),
                  ([GO, "conformance"], "ALL PASS (20/20)"),
                  ([GO, "sigma-conformance"], "ALL PASS (30/30"),
                  ([sys.executable, "tests/differential.py"], "ALL AGREE (43/43)")):
    p = subprocess.run(cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]
    print(last)
    ok &= p.returncode == 0 and want in last
# both impls agree on the repo's own store, warnings included
py = subprocess.run([sys.executable, "impl/warrant.py", "verify"], capture_output=True, text=True).stdout.strip().splitlines()[-1]
go = subprocess.run([GO, "verify", ".warrants"], capture_output=True, text=True).stdout.strip().splitlines()[-1]
print("py:", py); print("go:", go)
ok &= py == go and "0 errors" in py
print("warrant opus review dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
