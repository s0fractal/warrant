#!/usr/bin/env python3
"""Adjudication check for the Gemini GOV-001 rev 2 gate review (repo root)."""
import importlib.util, json, subprocess, sys
spec = importlib.util.spec_from_file_location('W', 'impl/warrant.py')
W = importlib.util.module_from_spec(spec); spec.loader.exec_module(W)
ok = True
# Gemini's probe: a check reason cannot name a claim in-band (closed schema)
w = json.load(open("examples/propose.warrant.json"))
w["body"]["because"].append({
    "kind": "check", "check": "05"*32, "runtime": "cmd@v1", "verdict": "pass",
    "transcript": "ca"*32, "qualifies_claim": "some_hash"})
errs = W.validate_body(w["body"])
print("closed-schema probe:", errs)
ok &= any("unknown fields" in e for e in errs)
for cmd, want in ((["impl/warrant.py","selftest"], "ALL PASS"),
                  (["impl/warrant.py","conformance"], "ALL PASS (20/20)"),
                  (["tests/differential.py"], "ALL AGREE (43/43)"),
                  (["tests/negative.py"], "NEGATIVE: ALL AGREE")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]
    print(last)
    ok &= p.returncode == 0 and want in last
print("gov001 gate 2 dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
