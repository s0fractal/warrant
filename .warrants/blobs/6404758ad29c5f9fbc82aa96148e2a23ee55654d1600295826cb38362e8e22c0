#!/usr/bin/env python3
"""Adjudication check for the SPEC v0.3 implementation gate (repo root)."""
import subprocess, sys
GO = "./impl-go/warrant-go"
ok = True
for cmd, want in (([sys.executable, "impl/warrant.py", "selftest"], "SELFTEST: ALL PASS"),
                  ([sys.executable, "impl/warrant.py", "conformance"], "ALL PASS (20/20)"),
                  ([GO, "selftest"], "ALL PASS (7/7)"),
                  ([GO, "conformance"], "ALL PASS (20/20)"),
                  ([sys.executable, "tests/differential.py"], "ALL AGREE (43/43)"),
                  ([sys.executable, "tests/negative.py"], "NEGATIVE: ALL AGREE"),
                  ([sys.executable, "tests/settlement.py"], "SETTLEMENT: ALL AGREE")):
    p = subprocess.run(cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]
    print(last)
    ok &= p.returncode == 0 and want in last
# plain-mode regression on the two real stores, both impls byte-agreeing
for store in (".warrants",):
    py = subprocess.run([sys.executable, "impl/warrant.py", "--store", store, "verify"],
                        capture_output=True, text=True).stdout
    go = subprocess.run([GO, "verify", store], capture_output=True, text=True).stdout
    same = py.strip().splitlines()[-1] == go.strip().splitlines()[-1] and "0 errors" in py
    print(f"{store}: {py.strip().splitlines()[-1]} | parity {same}")
    ok &= same
print("v0.3 implementation gate verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
