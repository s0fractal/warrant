#!/usr/bin/env python3
"""Adjudication check: Kimi K3 spec-review fixes (run from warrant repo root).

Re-runs the cross-impl suites the fixes touch and asserts the exact pass lines.
Bundled Σ-GLYPH oracle (impl/sigma_glyph.py) is used if SIGMA_GLYPH is unset, so
this re-runs offline with no separate clone. Exit 0 iff every gate passes."""
import os, subprocess, sys
root = os.getcwd()
env = dict(os.environ, WARRANT_REQUIRE_SIGMA="1")
sg = os.path.expanduser("~/Projects/sigma-glyph/impl")
if os.path.exists(os.path.join(sg, "sigma_glyph.py")):
    env["SIGMA_GLYPH"] = sg
# both implementations must exist for the differential/negative harnesses
b = subprocess.run(["go", "build", "-o", "warrant-go", "."], cwd=os.path.join(root, "impl-go"),
                   capture_output=True, text=True, env=env)
ok = b.returncode == 0
print("go build OK" if ok else "go build FAILED\n" + b.stderr)
gates = (
    (["python3", "impl/warrant.py", "conformance", "examples"], "CONFORMANCE: ALL PASS"),
    (["./impl-go/warrant-go", "conformance", "examples"], "CONFORMANCE: ALL PASS"),
    (["python3", "impl/warrant.py", "selftest"], "SELFTEST: ALL PASS"),
    (["python3", "tests/differential.py"], "DIFFERENTIAL: ALL AGREE"),
    (["python3", "tests/negative.py"], "NEGATIVE: ALL AGREE"),
    (["python3", "tests/hostile.py"], "HOSTILE: ALL PASS"),
    (["python3", "tests/settlement.py"], "SETTLEMENT: ALL AGREE"),
    (["python3", "tests/pedantic_edges.py"], "PEDANTIC-EDGES: ALL AGREE"),
    (["python3", "tests/ski_policy.py"], "SKI-POLICY: ALL PASS"),
)
for cmd, want in gates:
    p = subprocess.run(cmd, capture_output=True, text=True, env=env)
    last = p.stdout.strip().splitlines()[-1] if p.stdout.strip() else "(no output)"
    print(f"{'ok ' if (p.returncode == 0 and want in p.stdout) else 'FAIL'} {' '.join(cmd)} -> {last}")
    ok &= p.returncode == 0 and want in p.stdout
print("kimi-k3 review fixes verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
