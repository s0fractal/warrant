#!/usr/bin/env python3
"""Adjudication check: Gemini 3.1 Pro Ed25519 crypto-audit fixes (repo root)."""
import os, subprocess, sys
root=os.getcwd(); ok=True
subprocess.run(["cargo","build","--release"],cwd=os.path.join(root,"impl-rs"),capture_output=True)
subprocess.run(["go","build","-o","warrant-go","."],cwd=os.path.join(root,"impl-go"),capture_output=True)
sg=os.path.expanduser("~/Projects/sigma-glyph/impl"); env=dict(os.environ)
if os.path.exists(os.path.join(sg,"sigma_glyph.py")): env["SIGMA_GLYPH"]=sg
gates=[
 (["python3","impl/warrant.py","conformance","examples"],"CONFORMANCE: ALL PASS"),
 (["./impl-go/warrant-go","conformance","examples"],"CONFORMANCE: ALL PASS"),
 (["./impl-rs/target/release/warrant-rs","conformance","examples"],"RUST-WARRANT CONFORMANCE: ALL PASS"),
 (["./impl-rs/target/release/warrant-rs","edtest"],"ED25519 SELFTEST: ALL PASS"),
 (["python3","tests/differential.py"],"DIFFERENTIAL: ALL AGREE"),
 (["python3","tests/ed25519_differential.py","--n","200"],"ED25519-DIFFERENTIAL: ALL AGREE"),
 (["python3","tests/negative.py"],"NEGATIVE: ALL AGREE"),
 (["python3","tests/hostile.py"],"HOSTILE: ALL PASS"),
 (["python3","tests/fuzz_differential.py","--iters","150","--seed","1337"],"FUZZ-DIFFERENTIAL: ALL AGREE"),
 (["python3","impl/warrant.py","selftest"],"SELFTEST: ALL PASS")]
for cmd,want in gates:
    p=subprocess.run(cmd,capture_output=True,text=True,env=env)
    last=p.stdout.strip().splitlines()[-1] if p.stdout.strip() else "(no output)"
    good=p.returncode==0 and want in p.stdout
    print(f"{'ok ' if good else 'FAIL'} {' '.join(cmd[:3])} -> {last}"); ok&=good
print("ed25519 audit fixes verified" if ok else "CHECK FAILED"); sys.exit(0 if ok else 1)
