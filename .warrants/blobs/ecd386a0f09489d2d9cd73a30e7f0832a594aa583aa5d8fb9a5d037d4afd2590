#!/usr/bin/env python3
"""Adjudication check for the Codex GOV-001 gate review (run from repo root)."""
import hashlib, importlib.util, json, subprocess, sys
spec = importlib.util.spec_from_file_location('W', 'impl/warrant.py')
W = importlib.util.module_from_spec(spec); spec.loader.exec_module(W)
ok = True
# the byte-novelty probe: format cannot distinguish byte from claim novelty
ca = hashlib.sha256(b'#!/bin/sh\nexit 0\n').hexdigest()
cb = hashlib.sha256(b'#!/bin/sh\n# cosmetic comment\nexit 0\n').hexdigest()
base = {'warrant':'0.2','decision':'reject','subject':{'hash':'a'*64},'under':['b'*64],
        'because':[{'kind':'check','runtime':'cmd@v1','check':ca,'verdict':'pass'}],
        'evidence':['c'*64],'actor':{'id':'reviewer'},'prior':['d'*64],'ts':1}
alt = json.loads(json.dumps(base)); alt['because'][0]['check'] = cb
ok &= not W.validate_body(base) and not W.validate_body(alt)
ok &= W.warrant_id(base) != W.warrant_id(alt)
print("byte-novelty probe reproduced: both valid, ids differ")
for cmd, want in ((["impl/warrant.py","selftest"], "ALL PASS"),
                  (["impl/warrant.py","conformance"], "ALL PASS (20/20)"),
                  (["tests/differential.py"], "ALL AGREE (43/43)"),
                  (["tests/negative.py"], "NEGATIVE: ALL AGREE")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]
    print(last)
    ok &= p.returncode == 0 and want in last
print("gov001 gate dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
