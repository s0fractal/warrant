#!/usr/bin/env python3
"""Adjudication check: Gemini 3.1 Pro external-audit fixes (warrant repo root)."""
import os, subprocess, sys
root=os.getcwd(); ok=True
sg=os.path.expanduser("~/Projects/sigma-glyph/impl"); env=dict(os.environ)
if os.path.exists(os.path.join(sg,"sigma_glyph.py")): env["SIGMA_GLYPH"]=sg
b=subprocess.run(["go","build","-o","warrant-go","."],cwd=os.path.join(root,"impl-go"),capture_output=True,text=True,env=env)
ok=b.returncode==0; print("go build OK" if ok else "go build FAILED")
gates=[(["python3","impl/warrant.py","conformance","examples"],"CONFORMANCE: ALL PASS"),
 (["./impl-go/warrant-go","conformance","examples"],"CONFORMANCE: ALL PASS"),
 (["python3","impl/warrant.py","selftest"],"SELFTEST: ALL PASS"),
 (["python3","tests/differential.py"],"DIFFERENTIAL: ALL AGREE"),
 (["python3","tests/negative.py"],"NEGATIVE: ALL AGREE"),
 (["python3","tests/hostile.py"],"HOSTILE: ALL PASS"),
 (["python3","tests/settlement.py"],"SETTLEMENT: ALL AGREE"),
 (["python3","tests/pedantic_edges.py"],"PEDANTIC-EDGES: ALL AGREE"),
 (["python3","tests/ski_policy.py"],"SKI-POLICY: ALL PASS"),
 (["python3","tests/fuzz_differential.py","--iters","150","--seed","1337"],"FUZZ-DIFFERENTIAL: ALL AGREE"),
 (["python3","tests/fuzz_differential.py","--iters","150","--seed","4242"],"FUZZ-DIFFERENTIAL: ALL AGREE"),
 (["./impl-go/warrant-go","sigma-conformance",os.path.expanduser("~/Projects/sigma-glyph/tests/spec_conformance/vectors.json")],"SIGMA CONFORMANCE: ALL PASS")]
for cmd,want in gates:
    p=subprocess.run(cmd,capture_output=True,text=True,env=env)
    last=p.stdout.strip().splitlines()[-1] if p.stdout.strip() else "(no output)"
    good=p.returncode==0 and want in p.stdout
    print(f"{'ok ' if good else 'FAIL'} {' '.join(cmd[:3])} -> {last}"); ok&=good
print("gemini audit fixes verified" if ok else "CHECK FAILED"); sys.exit(0 if ok else 1)
